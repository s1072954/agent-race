# Copy to .env and fill in real keys. Never commit .env.
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/nemotron-3-super-120b-a12b

# Comma-separated root agents. The current default concentrates exploration budget on Qwen.
NVIDIA_MODELS=qwen/qwen3-coder-480b-a35b-instruct
NVIDIA_SUMMARY_MODEL=nvidia/nemotron-3-nano-30b-a3b

# Conservative trial-endpoint throttles.
NVIDIA_GLOBAL_RPM=8
NVIDIA_MODEL_RPM=2
NVIDIA_REQUEST_TIMEOUT_SECONDS=90
AGENT_RACE_MAX_PARALLEL_LLM_CALLS=1
AGENT_RACE_MAX_SUBAGENT_TASKS=1
AGENT_RACE_SUBAGENT_EVERY_TICKS=5

# Optional read-only exchange data. Do not enable trading permissions for these keys.
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_MARGIN_READ_ENABLED=false
BINANCE_QUERY_MAX_BORROWABLE=false

# Scheduler / dashboard.
AGENT_RACE_BASE_PATH=/agent-race
AGENT_RACE_TICK_SECONDS=180
AGENT_RACE_FALLBACK_TICK_SECONDS=900
AGENT_RACE_SUMMARY_EVERY_TICKS=5
AGENT_RACE_DB_PATH=data/agent_race.sqlite
AGENT_RACE_WORKSPACE_DIR=data/agents
AGENT_RACE_SCHEDULER_ENABLED=true

# Safety switches. MVP has no live order placement.
LIVE_TRADING_ENABLED=false
AGENT_RACE_ENABLE_SHELL_TOOLS=false
